    "# Toeplitz矩阵演示\n",
    "def demo_toeplitz():\n",
    "    \"\"\"\n",
    "    演示Toeplitz矩阵的构造及其与线性时不变系统的关系\n",
    "    \n",
    "    参数说明：\n",
    "    - c: 第一列元素（对应脉冲响应）\n",
    "    - r: 第一行元素\n",
    "    - T: Toeplitz矩阵\n",
    "    \"\"\"\n",
    "    from scipy.linalg import toeplitz\n",
    "    \n",
    "    # 创建Toeplitz矩阵示例\n",
    "    # 典型应用：FIR滤波器的卷积矩阵\n",
    "    \n",
    "    # 脉冲响应（因果FIR滤波器）\n",
    "    h = np.array([1.0, 0.5, 0.3, 0.1])  # 滤波器系数\n",
    "    \n",
    "    print(\"脉冲响应 h:\", h)\n",
    "    \n",
    "    # 创建Toeplitz矩阵（用于卷积 y = H @ x）\n",
    "    # 假设输入信号长度N=8，输出信号长度M=8+len(h)-1=11\n",
    "    N = 8  # 输入信号长度\n",
    "    M = N + len(h) - 1  # 输出信号长度\n",
    "    \n",
    "    # 第一列：脉冲响应，后面补0\n",
    "    c = np.concatenate([h, np.zeros(N-1)])\n",
    "    # 第一行：h[0] 后面补0\n",
    "    r = np.concatenate([h[:1], np.zeros(N-1)])\n",
    "    \n",
    "    T = toeplitz(c, r)\n",
    "    \n",
    "    print(\"\\nToeplitz矩阵 (11x8):\")\n",
    "    print(T.round(3))\n",
    "    \n",
    "    # 输入信号\n",
    "    x = np.array([1, 2, 3, 4, 5, 6, 7, 8], dtype=float)\n",
    "    print(\"\\n输入信号 x:\", x)\n",
    "    \n",
    "    # 卷积计算\n",
    "    y_conv = np.convolve(h, x)\n",
    "    y_matmul = T @ x\n",
    "    \n",
    "    print(\"\\n卷积结果（np.convolve）:\", y_conv.round(3))\n",
    "    print(\"矩阵乘法结果（T @ x）:\", y_matmul.round(3))\n",
    "    print(f\"两种方法结果一致: {np.allclose(y_conv, y_matmul)}\")\n",
    "    \n",
    "    # Toeplitz矩阵特性可视化\n",
    "    fig, axes = plt.subplots(1, 3, figsize=(15, 4))\n",
    "    \n",
    "    # Toeplitz矩阵结构\n",
    "    ax1 = axes[0]\n",
    "    im1 = ax1.imshow(T, cmap='Blues', aspect='auto')\n",
    "    ax1.set_title('Toeplitz矩阵结构', fontsize=12)\n",
    "    ax1.set_xlabel('列索引', fontsize=11)\n",
    "    ax1.set_ylabel('行索引', fontsize=11)\n",
    "    plt.colorbar(im1, ax=ax1, shrink=0.8)\n",
    "    \n",
    "    # 标记对角线\n",
    "    ax2 = axes[1]\n",
    "    im2 = ax2.imshow(T, cmap='viridis', aspect='auto')\n",
    "    ax2.set_title('每条对角线元素相同', fontsize=12)\n",
    "    ax2.set_xlabel('列索引', fontsize=11)\n",
    "    ax2.set_ylabel('行索引', fontsize=11)\n",
    "    plt.colorbar(im2, ax=ax2, shrink=0.8)\n",
    "    \n",
    "    # 输入输出信号\n",
    "    ax3 = axes[2]\n",
    "    ax3.stem(range(len(x)), x, linefmt='b-', markerfmt='bo', basefmt='k-', label='输入x')\n",
    "    ax3.stem(range(len(y_conv)), y_conv, linefmt='r-', markerfmt='r^', basefmt='k-', label='输出y')\n",
    "    ax3.set_xlabel('采样索引', fontsize=11)\n",
    "    ax3.set_ylabel('幅度', fontsize=11)\n",
    "    ax3.set_title('线性时不变系统响应', fontsize=12)\n",
    "    ax3.legend()\n",
    "    ax3.grid(True, alpha=0.3)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "    \n",
    "    # 循环矩阵（Toeplitz的特例）\n",
    "    print(\"\\n--- 循环矩阵（Toeplitz的循环扩展）---\")\n",
    "    \n",
    "    # 创建循环矩阵\n",
    "    c_circ = np.concatenate([[h[0]], h[:0:-1], np.zeros(max(0, N-len(h)-1))])\n",
    "    r_circ = np.concatenate([h[:1], np.zeros(N-1)])\n",
    "    circ_matrix = toeplitz(c_circ, r_circ)\n",
    "    \n",
    "    print(\"循环矩阵:\")\n",
    "    print(circ_matrix.round(3))\n",
    "    \n",
    "    # 循环卷积（频域乘法）\n",
    "    y_circ = np.fft.ifft(np.fft.fft(T[:N, :N], n=N) * np.fft.fft(x)).real\n",
    "    print(\"\\n循环卷积结果:\", y_circ.round(3))\n",
    "    \n",
    "    return h, x, T, y_conv\n",
    "\n",
    "h, x, T, y_conv = demo_toeplitz()"
   ]
