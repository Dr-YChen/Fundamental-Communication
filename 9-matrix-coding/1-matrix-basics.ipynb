    "    image = (0.5 + 0.3 * np.sin(20*X*np.pi) * np.sin(20*Y*np.pi) + \n",
    "             0.2 * np.cos(10*X*np.pi + 5*Y*np.pi))\n",
    "    image = (image * 255).astype(np.uint8)\n",
    "    \n",
    "    print(\"原始图像形状:\", image.shape)\n",
    "    \n",
    "    # 对图像进行SVD分解\n",
    "    U, s, Vh = np.linalg.svd(image, full_matrices=False)\n",
