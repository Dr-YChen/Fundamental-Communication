    "### 3.8 Woodbury恒等式演示"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Woodbury恒等式演示\n",
    "def demo_woodbury():\n",
    "    \"\"\"\n",
    "    演示Woodbury恒等式在矩阵求逆中的应用\n",
    "    \n",
    "    恒等式: (A + UCU^H)^{-1} = A^{-1} - A^{-1}U(C^{-1} + U^HA^{-1}U)^{-1}U^HA^{-1}\n",
    "    \n",
    "    用途: 当A是大矩阵的逆但已知时，避免直接对大矩阵求逆\n",
    "    \"\"\"\n",
    "    # 参数设置\n",
    "    np.random.seed(222)\n",
    "    \n",
    "    # 创建基础矩阵A（假设A是正定的）\n",
    "    n = 100\n",
    "    A = np.random.randn(n, n)\n",
    "    A = A @ A.T + np.eye(n)  # 确保正定\n",
    "    \n",
    "    # 低秩更新矩阵 U\n",
    "    k = 5  # 低秩\n",
    "    U = np.random.randn(n, k)\n",
    "    C = np.eye(k)  # C可以是任意可逆矩阵\n",
    "    \n",
    "    print(f\"矩阵维度: A({n}x{n}), U({n}x{k}), C({k}x{k})\")\n",
    "    print(f\"低秩更新: k={k}\")\n",
    "    \n",
    "    # 直接求逆（基准）\n",
    "    A_inv = np.linalg.inv(A)\n",
    "    B_direct = np.linalg.inv(A + U @ C @ U.T)\n",
    "    \n",
    "    # 使用Woodbury恒等式\n",
    "    A_inv_U = A_inv @ U\n",
    "    temp = np.linalg.inv(C + U.T @ A_inv_U)\n",
    "    B_woodbury = A_inv - A_inv_U @ temp @ (U.T @ A_inv)\n",
    "    \n",
    "    print(f\"\\n直接求逆计算量: O({n}^3)\")\n",
    "    print(f\"Woodbury计算量: O({n}^3) + O({k}^3) (k << n时更高效)\")\n",
    "    \n",
    "    # 验证结果\n",
    "    error = np.linalg.norm(B_direct - B_woodbury, 'fro')\n",
    "    print(f\"\\n两种方法结果误差: {error:.2e}\")\n",
    "    \n",
    "    # 计算复杂度对比\n",
    "    print(\"\\n--- 计算复杂度分析 ---\")\n",
    "    print(f\"直接求逆: {2*n**3/1e6:.2f} MFLOPs\")\n",
    "    print(f\"Woodbury: {2*n**2*k + 2*k**3/1e6:.2f} MFLOPs (当k=5时)\")\n",
    "    \n",
    "    # 可视化误差随k变化\n",
    "    k_range = [2, 5, 10, 20, 50]\n",
    "    errors = []\n",
    "    for k_test in k_range:\n",
    "        U_test = np.random.randn(n, k_test)\n",
    "        A_inv_U_test = A_inv @ U_test\n",
    "        C_test = np.eye(k_test)\n",
    "        temp_test = np.linalg.inv(C_test + U_test.T @ A_inv_U_test)\n",
    "        B_woodbury_test = A_inv - A_inv_U_test @ temp_test @ (U_test.T @ A_inv)\n",
    "        B_direct_test = np.linalg.inv(A + U_test @ C_test @ U_test.T)\n",
    "        errors.append(np.linalg.norm(B_direct_test - B_woodbury_test, 'fro'))\n",
    "    \n",
    "    fig, ax = plt.subplots(figsize=(8, 4))\n",
    "    ax.plot(k_range, errors, 'bo-', linewidth=2, markersize=8)\n",
    "    ax.set_xlabel('低秩更新维度 k', fontsize=11)\n",
    "    ax.set_ylabel('误差 ||B_direct - B_woodbury||_F', fontsize=11)\n",
    "    ax.set_title('Woodbury恒等式误差 vs 低秩维度', fontsize=12)\n",
    "    ax.grid(True, alpha=0.3)\n",
    "    ax.set_yscale('log')\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "    \n",
    "    print(\"\\nWoodbury恒等式应用场景：\")\n",
    "    print(\"1. 大型矩阵的求逆问题（当矩阵可以表示为小矩阵的更新时）\")\n",
    "    print(\"2. 信道估计中的矩阵求逆\")\n",
    "    print(\"3. 卡尔曼滤波中的协方差更新\")\n",
    "    print(\"4. 高斯过程回归中的矩阵求逆\")\n",
    "    \n",
    "    return A, U, C, B_direct, B_woodbury\n",
    "\n",
    "A, U, C, B_direct, B_woodbury = demo_woodbury()"
