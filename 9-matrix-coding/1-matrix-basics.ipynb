   "source": [
    "### 3.1 矩阵基本运算演示"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 矩阵基本运算演示\n",
    "def demo_basic_operations():\n",
    "    \"\"\"\n",
    "    演示矩阵的基本运算：加减乘除、转置、共轭、迹\n",
    "    \n",
    "    参数说明：\n",
    "    - A, B: 输入矩阵\n",
    "    - 结果展示各种运算结果\n",
    "    \"\"\"\n",
    "    # 创建测试矩阵\n",
    "    A = np.array([[1+1j, 2, 3], [4, 5+0.5j, 6], [7, 8, 9+0.3j]])  # 复数矩阵\n",
    "    B = np.array([[9, 8, 7], [6, 5, 4], [3, 2, 1]])\n",
    "    \n",
    "    print(\"矩阵A:\")\n",
    "    print(A)\n",
    "    print(\"\\n矩阵B:\")\n",
    "    print(B)\n",
    "    \n",
    "    # 转置：行列互换\n",
    "    print(\"\\n--- 转置 A.T ---\")\n",
    "    print(A.T)\n",
    "    \n",
    "    # 共轭：元素取复共轭\n",
    "    print(\"\\n--- 共轭 np.conj(A) ---\")\n",
    "    print(np.conj(A))\n",
    "    \n",
    "    # 共轭转置（厄米特转置）\n",
    "    print(\"\\n--- 共轭转置 A.conj().T ---\")\n",
    "    print(A.conj().T)\n",
    "    \n",
    "    # 迹：对角元素之和\n",
    "    print(\"\\n--- 迹 np.trace(A) ---\")\n",
    "    print(f\"tr(A) = {np.trace(A)}\")\n",
    "    \n",
    "    # 矩阵加法\n",
    "    print(\"\\n--- 加法 A + B ---\")\n",
    "    print(A + B)\n",
    "    \n",
    "    # 矩阵乘法\n",
    "    print(\"\\n--- 乘法 A @ B ---\")\n",
    "    print(A @ B)\n",
    "    \n",
    "    # 矩阵除法（通过求逆）\n",
    "    print(\"\\n--- 除法 A @ np.linalg.inv(B) ---\")\n",
    "    print(A @ np.linalg.inv(B))\n",
    "    \n",
    "    # 行列式\n",
    "    print(\"\\n--- 行列式 np.linalg.det(A) ---\")\n",
    "    print(f\"det(A) = {np.linalg.det(A):.4f}\")\n",
    "    \n",
    "    return A, B\n",
    "\n",
    "A, B = demo_basic_operations()"
   ]
