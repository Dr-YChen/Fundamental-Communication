    "# 伪逆（Moore-Penrose）演示\n",
    "def demo_pseudoinverse():\n",
    "    \"\"\"\n",
    "    演示伪逆的计算和最小二乘问题的求解\n",
    "    \n",
    "    参数说明：\n",
    "    - A: 输入矩阵（可能秩亏）\n",
    "    - A_pinv: 伪逆矩阵\n",
    "    - x_ls: 最小二乘解\n",
    "    \"\"\"\n",
    "    # 创建秩亏矩阵（行数 > 列数）\n",
    "    np.random.seed(111)\n",
    "    m, n = 5, 3\n",
    "    A = np.random.randn(m, n)\n",
    "    \n",
    "    # 使其秩亏（添加相关行）\n",
    "    A[4, :] = A[0, :] + 0.5 * A[1, :]  # 最后一行是前两行的线性组合\n",
    "    \n",
    "    b = np.random.randn(m)\n",
    "    \n",
    "    print(\"矩阵A (5x3, 秩亏):\")\n",
    "    print(A)\n",
    "    print(f\"\\n矩阵A的秩: {np.linalg.matrix_rank(A)}\")\n",
    "    print(f\"向量b:\", b)\n",
    "    \n",
    "    # 计算伪逆\n",
    "    A_pinv = np.linalg.pinv(A)\n",
    "    \n",
    "    print(\"\\n--- 伪逆A^+ ---\")\n",
    "    print(A_pinv)\n",
    "    \n",
    "    # 验证伪逆的性质\n",
    "    print(\"\\n--- 伪逆性质验证 ---\")\n",
    "    print(f\"A @ A^+ @ A ≈ A: {np.allclose(A @ A_pinv @ A, A)}\")\n",
    "    print(f\"A^+ @ A @ A^+ ≈ A^+: {np.allclose(A_pinv @ A @ A_pinv, A_pinv)}\")\n",
    "    \n",
    "    # 最小二乘解（超定方程组）\n",
    "    x_ls = A_pinv @ b\n",
    "    \n",
    "    print(\"\\n--- 最小二乘解 ---\")\n",
    "    print(f\"x = A^+ @ b = {x_ls.round(4)}\")\n",
    "    \n",
    "    # 验证残差\n",
    "    residual = np.linalg.norm(A @ x_ls - b)\n",
    "    print(f\"残差 ||Ax - b|| = {residual:.4f}\")\n",
    "    \n",
    "    # 与标准最小二乘对比\n",
    "    x_lstsq, residuals, rank, s = np.linalg.lstsq(A, b, rcond=None)\n",
    "    print(f\"\\n使用np.linalg.lstsq验证: x = {x_lstsq.round(4)}\")\n",
    "    \n",
    "    return A, A_pinv, b, x_ls\n",
    "\n",
    "A, A_pinv, b, x_ls = demo_pseudoinverse()"
   ]
  },
