    "    \n",
    "    fig, axes = plt.subplots(2, len(k_values) + 1, figsize=(15, 6))\n",
    "    \n",
    "    # 原始图像\n",
    "    ax = axes[0, 0]\n",
    "    ax.imshow(image, cmap='gray')\n",
    "    ax.set_title('原始图像', fontsize=10)\n",
    "    ax.axis('off')\n",
    "    \n",
