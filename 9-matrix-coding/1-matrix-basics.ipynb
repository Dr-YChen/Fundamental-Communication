    "        \n",
    "        # 计算压缩比和信息损失\n",
    "        compression_ratio = image.size / (k * (image.shape[0] + image.shape[1] + 1))\n",
    "        error = np.linalg.norm(image.astype(float) - image_reconstructed.astype(float), 'fro')\n",
