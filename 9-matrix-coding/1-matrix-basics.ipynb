    "### 3.2 矩阵范数对比"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 矩阵范数演示\n",
    "def demo_matrix_norms():\n",
    "    \"\"\"\n",
    "    演示不同矩阵范数的计算和对比\n",
    "    \n",
    "    参数说明：\n",
    "    - Frobenius范数：矩阵元素平方和的平方根\n",
    "    - 谱范数：最大奇异值\n",
    "    - 核范数：奇异值之和\n",
    "    \"\"\"\n",
    "    # 创建测试矩阵\n",
    "    np.random.seed(42)\n",
    "    A = np.random.randn(4, 3) + 1j * np.random.randn(4, 3)  # 复数矩阵\n",
    "    \n",
    "    print(\"矩阵A:\")\n",
    "    print(A)\n",
    "    \n",
    "    # Frobenius范数：||A||_F = sqrt(sum(|A_ij|^2))\n",
    "    fro_norm = np.linalg.norm(A, 'fro')\n",
    "    \n",
    "    # 谱范数：最大奇异值\n",
    "    spec_norm = np.linalg.norm(A, 2)\n",
    "    \n",
    "    # 核范数：奇异值之和\n",
    "    _, s, _ = np.linalg.svd(A)\n",
    "    nuclear_norm = np.sum(s)\n",
    "    \n",
    "    # l1范数（最大列和）\n",
    "    l1_norm = np.linalg.norm(A, 1)\n",
    "    \n",
    "    # l_inf范数（最大行和）\n",
    "    linf_norm = np.linalg.norm(A, np.inf)\n",
    "    \n",
    "    print(\"\\n--- 矩阵范数 ---\")\n",
    "    print(f\"Frobenius范数 ||A||_F = {fro_norm:.4f}\")\n",
    "    print(f\"谱范数 ||A||_2 = {spec_norm:.4f}\")\n",
    "    print(f\"核范数 ||A||_* = {nuclear_norm:.4f}\")\n",
    "    print(f\"l1范数 ||A||_1 = {l1_norm:.4f}\")\n",
    "    print(f\"l_inf范数 ||A||_inf = {linf_norm:.4f}\")\n",
    "    \n",
    "    # 验证范数不等式\n",
    "    print(\"\\n--- 范数不等式验证 ---\")\n",
    "    print(f\"||A||_2 <= ||A||_F = {spec_norm:.4f} <= {fro_norm:.4f}\")\n",
    "    print(f\"||A||_F <= sqrt(m*n)*||A||_2 = {fro_norm:.4f} <= {np.sqrt(12)*spec_norm:.4f}\")\n",
    "    \n",
    "    return A, fro_norm, spec_norm, nuclear_norm\n",
    "\n",
    "A, fro_norm, spec_norm, nuclear_norm = demo_matrix_norms()"
   ]
  },
