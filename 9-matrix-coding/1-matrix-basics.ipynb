    "### 3.4 SVD奇异值分解与图像压缩"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# SVD奇异值分解演示\n",
    "def demo_svd():\n",
    "    \"\"\"\n",
    "    演示SVD分解及截断SVD的最佳近似性质\n",
    "    \n",
    "    参数说明：\n",
    "    - U, s, Vh: SVD分解的三个矩阵\n",
    "    - k: 保留的奇异值个数\n",
    "    - A_k: 秩k最佳近似\n",
    "    \"\"\"\n",
    "    # 创建测试矩阵\n",
    "    np.random.seed(456)\n",
    "    m, n = 6, 5\n",
    "    A = np.random.randn(m, n)\n",
    "    \n",
    "    print(\"原始矩阵A:\")\n",
    "    print(A)\n",
    "    \n",
    "    # SVD分解\n",
    "    U, s, Vh = np.linalg.svd(A, full_matrices=False)\n",
    "    \n",
    "    print(\"\\n--- SVD分解结果 ---\")\n",
    "    print(\"左奇异向量矩阵U:\")\n",
    "    print(U)\n",
    "    print(\"\\n奇异值s:\")\n",
    "    print(s)\n",
    "    print(\"\\n右奇异向量矩阵Vh:\")\n",
    "    print(Vh)\n",
    "    \n",
    "    # 验证重构\n",
    "    Sigma = np.diag(s)\n",
    "    A_reconstructed = U @ Sigma @ Vh\n",
    "    print(f\"\\n重构误差: {np.linalg.norm(A - A_reconstructed):.2e}\")\n",
    "    \n",
    "    # 截断SVD演示\n",
    "    print(\"\\n--- 不同截断秩k的近似效果 ---\")\n",
    "    for k in [1, 2, 3]:\n",
    "        # 保留前k个奇异值\n",
    "        U_k = U[:, :k]\n",
    "        s_k = s[:k]\n",
    "        Vh_k = Vh[:k, :]\n",
    "        \n",
    "        # 重建矩阵\n",
    "        A_k = U_k @ np.diag(s_k) @ Vh_k\n",
    "        \n",
    "        # 计算误差\n",
    "        error = np.linalg.norm(A - A_k, 'fro')\n",
    "        \n",
    "        print(f\"k={k}: ||A - A_k||_F = {error:.4f}\")\n",
    "    \n",
    "    # 可视化奇异值分布\n",
    "    fig, axes = plt.subplots(1, 2, figsize=(12, 4))\n",
    "    \n",
    "    # 奇异值柱状图\n",
    "    ax1 = axes[0]\n",
    "    ax1.bar(range(1, len(s)+1), s, color='steelblue', alpha=0.8)\n",
    "    ax1.set_xlabel('奇异值索引', fontsize=11)\n",
    "    ax1.set_ylabel('奇异值', fontsize=11)\n",
    "    ax1.set_title('奇异值分布', fontsize=12)\n",
    "    ax1.grid(True, alpha=0.3, axis='y')\n",
    "    \n",
    "    # 累积能量\n",
    "    ax2 = axes[1]\n",
    "    cumulative = np.cumsum(s**2) / np.sum(s**2)\n",
    "    ax2.plot(range(1, len(s)+1), cumulative, 'o-', color='green', linewidth=2)\n",
    "    ax2.axhline(y=0.9, color='red', linestyle='--', alpha=0.7, label='90%能量')\n",
    "    ax2.axhline(y=0.95, color='orange', linestyle='--', alpha=0.7, label='95%能量')\n",
    "    ax2.set_xlabel('保留的奇异值个数', fontsize=11)\n",
    "    ax2.set_ylabel('累积能量占比', fontsize=11)\n",
    "    ax2.set_title('奇异值累积能量分布', fontsize=12)\n",
    "    ax2.legend()\n",
    "    ax2.grid(True, alpha=0.3)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "    \n",
    "    return A, U, s, Vh\n",
    "\n",
    "A, U, s, Vh = demo_svd()"
   ]
