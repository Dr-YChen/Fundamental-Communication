    "### 3.3 特征值分解与对角化"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 特征值分解演示\n",
    "def demo_eigen_decomposition():\n",
    "    \"\"\"\n",
    "    演示矩阵的特征值分解和对角化过程\n",
    "    \n",
    "    参数说明：\n",
    "    - eigenvalues: 特征值\n",
    "    - eigenvectors: 特征向量矩阵\n",
    "    - 对角化：A = V @ Lambda @ inv(V)\n",
    "    \"\"\"\n",
    "    # 创建对称矩阵（保证实特征值）\n",
    "    np.random.seed(123)\n",
    "    A = np.array([[3, 1, 0], [1, 2, 0.5], [0, 0.5, 1]], dtype=float)\n",
    "    \n",
    "    print(\"对称矩阵A:\")\n",
    "    print(A)\n",
    "    \n",
    "    # 特征值分解\n",
    "    eigenvalues, eigenvectors = np.linalg.eig(A)\n",
    "    \n",
    "    print(\"\\n--- 特征值 ---\")\n",
    "    print(eigenvalues)\n",
    "    \n",
    "    print(\"\\n--- 特征向量矩阵 V ---\")\n",
    "    print(eigenvectors)\n",
    "    \n",
    "    # 验证 Av = λv\n",
    "    print(\"\\n--- 验证 Av = λv ---\")\n",
    "    for i in range(len(eigenvalues)):\n",
    "        lhs = A @ eigenvectors[:, i]\n",
    "        rhs = eigenvalues[i] * eigenvectors[:, i]\n",
    "        print(f\"λ_{i}={eigenvalues[i]:.4f}: ||Av - λv|| = {np.linalg.norm(lhs - rhs):.2e}\")\n",
    "    \n",
    "    # 对角化\n",
    "    V = eigenvectors\n",
    "    Lambda = np.diag(eigenvalues)\n",
    "    A_reconstructed = V @ Lambda @ np.linalg.inv(V)\n",
    "    \n",
    "    print(\"\\n--- 对角化验证 A = V Λ V^{-1} ---\")\n",
    "    print(\"重建矩阵:\")\n",
    "    print(A_reconstructed)\n",
    "    print(f\"重建误差: {np.linalg.norm(A - A_reconstructed):.2e}\")\n",
    "    \n",
    "    # 可视化特征值分布\n",
    "    fig, axes = plt.subplots(1, 2, figsize=(12, 4))\n",
    "    \n",
    "    # 特征值在复平面的位置\n",
    "    ax1 = axes[0]\n",
    "    ax1.scatter(eigenvalues.real, eigenvalues.imag, s=100, c='red', zorder=5)\n",
    "    ax1.axhline(y=0, color='gray', linestyle='--', alpha=0.5)\n",
    "    ax1.axvline(x=0, color='gray', linestyle='--', alpha=0.5)\n",
    "    ax1.set_xlabel('实部', fontsize=11)\n",
    "    ax1.set_ylabel('虚部', fontsize=11)\n",
    "    ax1.set_title('特征值在复平面的位置', fontsize=12)\n",
    "    ax1.grid(True, alpha=0.3)\n",
    "    \n",
    "    # 特征向量可视化\n",
    "    ax2 = axes[1]\n",
    "    colors = ['blue', 'green', 'orange']\n",
    "    origin = np.array([[0, 0], [0, 0]])\n",
    "    for i in range(len(eigenvalues)):\n",
    "        vec = eigenvectors[:2, i]  # 只取前两个分量可视化\n",
    "        vec = vec / np.linalg.norm(vec)  # 归一化\n",
    "        ax2.quiver(*origin, vec[0], vec[1], color=colors[i], scale=5,\n",
    "                  label=f'λ{i+1}={eigenvalues[i]:.2f}')\n",
    "    ax2.set_xlim(-1.5, 1.5)\n",
    "    ax2.set_ylim(-1.5, 1.5)\n",
    "    ax2.set_xlabel('x', fontsize=11)\n",
    "    ax2.set_ylabel('y', fontsize=11)\n",
    "    ax2.set_title('特征向量方向', fontsize=12)\n",
    "    ax2.legend()\n",
    "    ax2.grid(True, alpha=0.3)\n",
    "    ax2.set_aspect('equal')\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "    \n",
    "    return A, eigenvalues, eigenvectors\n",
    "\n",
    "A, eigenvalues, eigenvectors = demo_eigen_decomposition()"
   ]
  },
  {
