# 信号1: 300Hz正弦波
signal1 = np.sin(2 * np.pi * 300 * t)

# 信号2: 500Hz正弦波
signal2 = np.sin(2 * np.pi * 500 * t)

# 信号3: 音调逐渐变化的信号
signal3 = np.sin(2 * np.pi * (400 + 200 * t) * t)

# 信号4: 幅度调制的信号
signal4 = (0.5 + 0.3 * np.sin(2 * np.pi * 10 * t)) * np.sin(2 * np.pi * 600 * t)

baseband_signals = [signal1, signal2, signal3, signal4]
signal_names = ['信道1 (300Hz)', '信道2 (500Hz)', '信道3 (扫频)', '信道4 (调幅600Hz)']

# 绘制基带信号
