### 3.3 TDM复用（交织）

```python
def tdm_multiplex(signals, samples_per_slot):
    """
    TDM复用：将多个信号交织到一个时序流中

    参数:
        signals: 信号列表
        samples_per_slot: 每个时隙的采样点数

    返回:
        tdm_stream: 复用后的时序流
    """
    num_channels = len(signals)

    # 创建时隙序列：按顺序填入每个信道的一个时隙
    tdm_stream = []

    # 每个信号取samples_per_slot个采样点
    for slot_idx in range(samples_per_slot):
        for ch_idx in range(num_channels):
            sample_idx = slot_idx  # 每个时隙取第slot_idx个采样点
            if sample_idx < len(signals[ch_idx]):
                tdm_stream.append(signals[ch_idx][sample_idx])

    return np.array(tdm_stream)

# 简化的TDM复用实现
def tdm_multiplex_simple(signals, samples_per_slot):
    """
    简化的TDM复用：将N个信号交织成1个时序流
    """
    num_channels = len(signals)
    num_slots = len(signals[0]) // samples_per_slot

    tdm_stream = []

    # 按帧处理
    for slot in range(samples_per_slot):
        for ch in range(num_channels):
            tdm_stream.append(signals[ch][slot])

    return np.array(tdm_stream)

# 执行TDM复用
# 为了简化，我们取前samples_per_slot个采样点进行演示
short_signals = [sig[:samples_per_slot] for sig in baseband_signals]
tdm_stream = tdm_multiplex_simple(short_signals, samples_per_slot)

print(f"原始信号总采样点: {samples_per_slot * num_channels}")
print(f"TDM流采样点: {len(tdm_stream)}")
print(f"压缩比: {samples_per_slot * num_channels / len(tdm_stream):.2f}")
```

