for i, (sig, name) in enumerate(zip(baseband_signals, signal_names)):
    axes[i].plot(t * 1000, sig, 'b-', linewidth=0.8)
    axes[i].set_xlabel('时间 (ms)')
    axes[i].set_ylabel('幅度')
    axes[i].set_title(name, fontsize=11)
    axes[i].grid(True, alpha=0.3)
