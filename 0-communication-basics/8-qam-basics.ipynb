    "axes[0].axhline(y=0, color='k', linewidth=0.5)\n",
    "axes[0].axvline(x=0, color='k', linewidth=0.5)\n",
    "axes[0].set_xlabel('同相分量 (I)', fontsize=12)\n",
    "axes[0].set_ylabel('正交分量 (Q)', fontsize=12)\n",
