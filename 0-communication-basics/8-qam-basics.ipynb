    "# 对比16-QAM、64-QAM、256-QAM的抗噪声性能\n",
    "def create_qam_constellation(M):\n",
    "    \"\"\"\n",
    "    创建M-QAM星座图\n",
    "    \n",
    "    参数：M - QAM阶数（必须是完全平方数）\n",
    "    返回：星座点数组\n",
    "    \"\"\"\n",
    "    k = int(np.log2(M))\n",
    "    n = int(np.sqrt(M))  # n×n星座图\n",
    "    \n",
    "    # 创建电平\n",
    "    levels = np.linspace(-(n-1), (n-1), n) / (n-1)\n",
    "    \n",
    "    # 生成星座点\n",
    "    constellation = []\n",
    "    for i in levels:\n",
    "        for j in levels:\n",
    "            constellation.append(i + 1j * j)\n",
    "    \n",
    "    return np.array(constellation)\n",
    "\n",
    "# 创建不同阶数的QAM星座图\n",
    "qam16 = create_qam_constellation(16)\n",
    "qam64 = create_qam_constellation(64)\n",
    "qam256 = create_qam_constellation(256)\n",
    "\n",
    "print(f\"16-QAM: {len(qam16)} 星座点, {int(np.log2(16))} 比特/符号\")\n",
    "print(f\"64-QAM: {len(qam64)} 星座点, {int(np.log2(64))} 比特/符号\")\n",
    "print(f\"256-QAM: {len(qam256)} 星座点, {int(np.log2(256))} 比特/符号\")"
