    "axes[0].grid(True, alpha=0.3)\n",
    "axes[0].set_xlim(-1.5, 1.5)\n",
    "axes[0].set_ylim(-1.5, 1.5)\n",
    "axes[0].set_aspect('equal')\n",
    "\n",
    "# 接收端星座图\n",
    "axes[1].scatter(rx_symbols.real, rx_symbols.imag, \n",
    "               c='red', s=100, alpha=0.7, edgecolors='black', linewidths=1)\n",
    "# 叠加标准星座点\n",
    "axes[1].scatter(qam16_constellation.real, qam16_constellation.imag, \n",
    "               c='gray', s=50, alpha=0.3, marker='x', label='标准星座点')\n",
    "axes[1].axhline(y=0, color='k', linewidth=0.5)\n",
    "axes[1].axvline(x=0, color='k', linewidth=0.5)\n",
    "axes[1].set_xlabel('同相分量 (I)', fontsize=12)\n",
    "axes[1].set_ylabel('正交分量 (Q)', fontsize=12)\n",
    "axes[1].set_title(f'接收端星座图 (SNR={snr_db}dB)', fontsize=14)\n",
    "axes[1].grid(True, alpha=0.3)\n",
    "axes[1].set_xlim(-1.5, 1.5)\n",
    "axes[1].set_ylim(-1.5, 1.5)\n",
    "axes[1].set_aspect('equal')\n",
    "axes[1].legend(loc='upper right')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"\\n分析：\")\n",
    "print(f\"  - 在SNR={snr_db}dB下，误码率为{ber:.4f}\")\n",
    "print(\"  - 接收端星座点围绕标准星座点随机扩散\")\n",
    "print(\"  - 扩散程度由噪声功率决定\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 3.3 噪声对QAM的影响"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 仿真不同SNR下16-QAM的接收星座图\n",
    "def simulate_qam_at_snr(snr_db, num_symbols=500):\n",
    "    \"\"\"\n",
    "    仿真指定SNR下的QAM传输\n",
    "    \"\"\"\n",
    "    # 生成随机比特\n",
    "    bits = np.random.randint(0, 2, num_symbols * 4)\n",
    "    \n",
    "    # 调制\n",
    "    tx_symbols = qam16_modulation(bits)\n",
    "    \n",
    "    # 添加噪声\n",
    "    rx_symbols = add_awgn_noise(tx_symbols, snr_db)\n",
    "    \n",
    "    # 解调\n",
    "    rx_bits = qam16_demodulation(rx_symbols)\n",
    "    \n",
    "    # 计算误码\n",
    "    errors = np.sum(bits != rx_bits)\n",
    "    ber = errors / len(bits)\n",
    "    \n",
    "    return tx_symbols, rx_symbols, ber\n",
    "\n",
    "# 测试不同SNR\n",
    "snr_levels = [5, 10, 15, 20]  # dB\n",
    "\n",
    "# 创建图形\n",
